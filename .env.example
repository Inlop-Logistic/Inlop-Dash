## INLOP Torre de Control — variables de entorno del backend (index.js)
##
## Copia este archivo a .env (no se commitea) para desarrollo local, o
## configura estas mismas claves en Railway para producción.

# ─── ControlT (tracking externo) ──────────────────────────
CONTROLT_USER=
CONTROLT_PASS=
CT_PUBLIC_USER=
CT_PUBLIC_PASS=

# ─── Supabase ──────────────────────────────────────────────
# Service role key del proyecto Supabase (gtyydandwcgoaratmnqh). Requerida
# para que este backend pueda escribir en tablas con RLS habilitado
# (ver appclienteinlop/supabase/migrations — notificaciones_cliente, Fase 3
# del INLOP Event Engine) y para la gestión de usuarios (Auth Admin API).
#
# NUNCA exponer esta clave al navegador ni commitearla en el repositorio.
# Sin esta variable, el backend cae a la anon key (ver aviso en consola al
# iniciar) y las políticas RLS de notificaciones_cliente bloquearán sus
# escrituras.
SUPABASE_SERVICE_KEY=

# ─── Otros ─────────────────────────────────────────────────
# Horas tras las cuales una solicitud sin actividad se considera huérfana
ORPHAN_HOURS=4

# Puerto del servidor (Railway lo inyecta automáticamente)
# PORT=3000
